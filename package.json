        "autoprefixer": "^10.4.16",
        "axios": "^1.5.1",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-prettier": "^5.0.0",
        "postcss": "^8.4.31",
        "svelte-fa": "^3.0.4",
        "tailwindcss": "^3.3.3"
